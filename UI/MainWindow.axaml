<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
        x:Class="AcerHelper.UI.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Acer Helper" CanResize="False" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual"
        Topmost="True" WindowDecorations="None" Background="Transparent">

  <!-- Win11 quick-settings flyout: one frameless acrylic window. The main card sits on the right
       (pinned to the tray). Options/Lighting open in a drawer area to its left: the window expands
       once (a clean resize on the modern DWM acrylic backdrop), and the drawer card slides in from
       behind the main card via a content transform (smooth, no per-frame window move). One window =
       nothing of ours bleeds through the acrylic. Backdrop/corners/placement live in code-behind. -->
  <Grid ColumnDefinitions="Auto,Auto">

    <!-- Drawer area: width is 0 (collapsed) or 368 (expanded), set once in code. The inner card slides
         within it (clipped) so it appears from behind the main card. -->
    <Border x:Name="DrawerHost" Grid.Column="0" Width="0" ClipToBounds="True">
      <Border x:Name="DrawerCard" Classes="root" Width="360" Margin="0,0,8,0" HorizontalAlignment="Right">
        <DockPanel Margin="14">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
            <Button Classes="icon" Content="&#x2190;" Command="{Binding CloseDrawerCommand}"/>
            <TextBlock x:Name="DrawerTitle" Grid.Column="1" Classes="h1" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </Grid>
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ContentControl x:Name="DrawerContentHost"/>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Border>

    <!-- Main quick panel -->
    <Border x:Name="MainCard" Classes="root" Grid.Column="1" Width="468">
      <DockPanel Margin="14">

        <!-- Header: device name + current-profile accent chip -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="2,2,2,12">
          <TextBlock Classes="h1" VerticalAlignment="Center" Text="{Binding DeviceName}"/>
          <Border Grid.Column="1" Classes="chip" IsVisible="{Binding HasProfile}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{DynamicResource AccentBrush}"/>
              <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                         Foreground="{DynamicResource AccentBrush}" Text="{Binding ProfileName}"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Footer: status text + drawer launch buttons -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="2,12,2,0">
          <TextBlock Classes="muted" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding Status}"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Options" Padding="14,5"
                    IsVisible="{Binding ShowOptions}" Command="{Binding OpenOptionsCommand}"/>
            <Button Classes="accent" Content="Lighting" Padding="14,5"
                    IsVisible="{Binding ShowLighting}" Command="{Binding OpenLightingCommand}"/>
          </StackPanel>
        </Grid>

        <!-- Body: capability sections, single full-width column. -->
        <ItemsControl ItemsSource="{Binding Sections}"/>

      </DockPanel>
    </Border>
  </Grid>
</Window>
