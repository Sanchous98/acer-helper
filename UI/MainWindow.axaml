<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
        x:Class="AcerHelper.UI.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Acer Helper" Width="468" CanResize="False" ShowInTaskbar="False"
        SizeToContent="Height" WindowStartupLocation="Manual"
        Topmost="True" SystemDecorations="None" Background="Transparent">

  <!-- Win11 quick-settings flyout: a frameless rounded acrylic body of fixed width. Options/Lighting
       open as a sub-page that slides in over the main panel (from the right) — the window never
       resizes or moves, so there's no DWM-blur flicker and no blurred strip beside the panel.
       Acrylic level + light-dismiss + tray placement live in code-behind. -->
  <Border Classes="root">
    <Panel>

      <!-- Main quick panel -->
      <DockPanel x:Name="MainPanel" Margin="14">

        <!-- Header: device name + current-profile accent chip -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="2,2,2,12">
          <TextBlock Classes="h1" VerticalAlignment="Center" Text="{Binding DeviceName}"/>
          <Border Grid.Column="1" Classes="chip" IsVisible="{Binding HasProfile}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{DynamicResource AccentBrush}"/>
              <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                         Foreground="{DynamicResource AccentBrush}" Text="{Binding ProfileName}"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Footer: status text + sub-page launch buttons -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="2,12,2,0">
          <TextBlock Classes="muted" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding Status}"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Options" Padding="14,5"
                    IsVisible="{Binding ShowOptions}" Command="{Binding OpenOptionsCommand}"/>
            <Button Classes="accent" Content="Lighting" Padding="14,5"
                    IsVisible="{Binding ShowLighting}" Command="{Binding OpenLightingCommand}"/>
          </StackPanel>
        </Grid>

        <!-- Body: capability sections, single full-width column. -->
        <ItemsControl ItemsSource="{Binding Sections}"/>

      </DockPanel>

      <!-- Sub-page (Options / Lighting): slides in over the main panel; parked off the right edge and
           clipped by the rounded root when closed. Capped to the main panel's height. -->
      <Border Classes="drawerpanel" Classes.shown="{Binding IsDrawerOpen}"
              Background="{DynamicResource AppAcrylicTint}"
              MaxHeight="{Binding #MainPanel.Bounds.Height}">
        <DockPanel Margin="14">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
            <Button Classes="icon" Content="&#x2190;" Command="{Binding CloseDrawerCommand}"/>
            <TextBlock Grid.Column="1" Classes="h1" VerticalAlignment="Center" Margin="6,0,0,0" Text="{Binding DrawerTitle}"/>
          </Grid>
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ContentControl Content="{Binding DrawerContent}"/>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Panel>
  </Border>
</Window>
