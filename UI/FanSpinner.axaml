<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AcerHelper.UI.FanSpinner"
             Width="21" Height="21">

  <!-- A standard 4-blade fan glyph: the blades rotate (RotateTransform driven from code at a calm,
       RPM-proportional speed), the hub sits static on top. Geometry is declarative; only the spin
       speed comes from code. F1 = non-zero fill so the blades meet solid at the centre. -->
  <Grid>
    <Path x:Name="Rotor" Stretch="Uniform" RenderTransformOrigin="50%,50%"
          Data="F1 M12,12 C8,8 8.5,2 12,2 C15.5,2 16,8 12,12 Z
                   M12,12 C16,8 22,8.5 22,12 C22,15.5 16,16 12,12 Z
                   M12,12 C16,16 15.5,22 12,22 C8.5,22 8,16 12,12 Z
                   M12,12 C8,16 2,15.5 2,12 C2,8.5 8,8 12,12 Z">
      <Path.RenderTransform>
        <RotateTransform/>
      </Path.RenderTransform>
    </Path>
    <Ellipse x:Name="Hub" Width="6" Height="6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
  </Grid>
</UserControl>
