<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:views="clr-namespace:AcerHelper.UI.Views"
             x:Class="AcerHelper.UI.App">

  <!-- Capability section -> view map. This is the dashboard "framework": MainViewModel exposes the
       section view-models (the full-width main column) and the drawer contents, and these templates
       render each one. A new feature/vendor section = a new SectionViewModel + a DataTemplate here;
       the shell (MainWindow) is untouched. -->
  <Application.DataTemplates>
    <DataTemplate DataType="vm:MonitorViewModel"><views:MonitorView/></DataTemplate>
    <DataTemplate DataType="vm:ProfilesViewModel"><views:ProfilesView/></DataTemplate>
    <DataTemplate DataType="vm:FansViewModel"><views:FansView/></DataTemplate>
    <DataTemplate DataType="vm:BatteryViewModel"><views:BatteryView/></DataTemplate>
    <!-- Drawer contents (hosted in the main window's slide-out side panel). -->
    <DataTemplate DataType="vm:OptionsViewModel"><views:OptionsView/></DataTemplate>
    <DataTemplate DataType="vm:LightingViewModel"><views:LightingView/></DataTemplate>
    <!-- Tuning drawer: the container + its GPU / CPU sub-views (rendered via ContentControl). -->
    <DataTemplate DataType="vm:TuningViewModel"><views:TuningView/></DataTemplate>
    <DataTemplate DataType="vm:GpuViewModel"><views:GpuView/></DataTemplate>
    <DataTemplate DataType="vm:CpuViewModel"><views:CpuView/></DataTemplate>

    <!-- Options-drawer row templates. Kept HERE (application scope) rather than inside OptionsView's
         ItemsControl.DataTemplates: an ItemsControl whose heterogeneous items were matched by a
         control-level DataTemplates collection rendered NOTHING (the rows never realised), while these same
         DataType templates resolve fine at application scope — which is how every other view is templated. -->
    <DataTemplate DataType="vm:ToggleRowViewModel" x:DataType="vm:ToggleRowViewModel">
      <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding IsEnabled}" ToolTip.Tip="{Binding Tip}">
        <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0" Text="{Binding Label}"/>
        <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsOn, Mode=TwoWay}"/>
      </Grid>
    </DataTemplate>
    <DataTemplate DataType="vm:ChoiceRowViewModel" x:DataType="vm:ChoiceRowViewModel">
      <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding IsEnabled}">
        <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0" Text="{Binding Label}"/>
        <ComboBox Grid.Column="1" MinWidth="110" VerticalAlignment="Center"
                  ItemsSource="{Binding Options}" SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"/>
      </Grid>
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <!-- Win11 geometry: in-page controls 4px, overlays/flyouts 8px (Avalonia defaults are 3/5). -->
      <CornerRadius x:Key="ControlCornerRadius">4</CornerRadius>
      <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>

      <!-- System accent (provided by the Fluent theme) as brushes: solid for the selected profile
           and the chip text/dot, translucent for the chip background. -->
      <SolidColorBrush x:Key="AccentBrush"     Color="{DynamicResource SystemAccentColor}" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.28" />

      <!-- Own, theme-aware brushes (the WinUI Card*/Layer*/TextFill* tokens don't exist in
           Avalonia 11.2). Translucent so they layer over the acrylic backdrop like Win11. -->
      <ResourceDictionary.ThemeDictionaries>
        <!-- AppAcrylicTint is the window's surface colour over the acrylic backdrop. It must stay
             fairly opaque or text washes out over bright wallpapers/windows (a near-transparent tint
             looks great on a dark desktop but breaks on a light one). ~85% keeps text readable on any
             background while still letting blurred colour through. This alpha is the see-through knob. -->
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppAcrylicTint" Color="#CCF3F3F3" />
          <SolidColorBrush x:Key="AppCard"        Color="#40FFFFFF" />
          <SolidColorBrush x:Key="AppCardStroke"  Color="#14000000" />
          <SolidColorBrush x:Key="AppMuted"       Color="#99000000" />
          <!-- Section headers (BATTERY / GPU / …). OPAQUE (not the semi-transparent AppMuted) so a header reads
               the SAME on every card regardless of the card's rendered darkness — a translucent header
               composited over a slightly-different card background looked brighter on some cards than others. -->
          <SolidColorBrush x:Key="AppSectionFg"   Color="#505050" />
          <!-- Neutral control surfaces (segmented buttons, icon-button hover), theme-aware so they read
               as subtle raised controls on either theme. Rest / hover-or-pressed. -->
          <SolidColorBrush x:Key="AppControl"      Color="#18000000" />
          <SolidColorBrush x:Key="AppControlHover" Color="#28000000" />
          <!-- Section-card acrylic. Theme-aware + a fairly dominant tint so the card keeps its tone (and
               text contrast) on ANY wallpaper — a near-transparent tint looks great on a matching desktop
               but washes out over the opposite one. TintOpacity/MaterialOpacity are the see-through knobs. -->
          <ExperimentalAcrylicMaterial x:Key="CardMaterial" BackgroundSource="Digger"
              TintColor="#FCFCFC" TintOpacity="0.6" MaterialOpacity="0.5"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppAcrylicTint" Color="#CC2A2A2A" />
          <SolidColorBrush x:Key="AppCard"        Color="#14FFFFFF" />
          <SolidColorBrush x:Key="AppCardStroke"  Color="#1FFFFFFF" />
          <SolidColorBrush x:Key="AppMuted"       Color="#B3FFFFFF" />
          <!-- See the Light dict: opaque section-header colour (not translucent AppMuted) so headers read the
               same on every card. Brighter than AppMuted's effective look so it stays crisp on any card. -->
          <SolidColorBrush x:Key="AppSectionFg"   Color="#D6D6D6" />
          <SolidColorBrush x:Key="AppControl"      Color="#22FFFFFF" />
          <SolidColorBrush x:Key="AppControlHover" Color="#33FFFFFF" />
          <ExperimentalAcrylicMaterial x:Key="CardMaterial" BackgroundSource="Digger"
              TintColor="#141414" TintOpacity="0.8" MaterialOpacity="0.6"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <!-- ColorPicker/ColorView ship in a separate package; their control templates must be added
         explicitly or the controls render nothing (empty zone swatches / missing colour field). -->
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>

    <!-- Acrylic-tinted, rounded root surface (the flyout body). -->
    <Style Selector="Border.root">
      <Setter Property="Background" Value="{DynamicResource AppAcrylicTint}" />
      <Setter Property="CornerRadius" Value="{DynamicResource OverlayCornerRadius}" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <!-- A content card: a subtle translucent layer over the acrylic. Compact padding keeps the dense
         single-panel layout short (two of these sit side by side in the columns area). -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource AppCard}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppCardStroke}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="ExperimentalAcrylicBorder.card">
      <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AppSectionFg}" />
      <Setter Property="Margin" Value="2,0,0,10" />
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.metric">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource AppMuted}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Performance-mode segmented button. Neutral control surface (theme-aware token) keeps unselected
         segments visible on the acrylic; the selected one is filled with the system accent. -->
    <Style Selector="Button.seg">
      <Setter Property="Background" Value="{DynamicResource AppControl}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppCardStroke}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
      <Setter Property="Padding" Value="2,6" />
      <Setter Property="Margin" Value="3,0" />
      <!-- MinHeight so single-line (Эко/Turbo) and wrapped two-line (Производительность) segments share one
           height and stay aligned; FontSize 10 gives the wrapped labels a little more room in the 5-segment row. -->
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- The active segment: filled with the mode's OWN signature colour, bound per-item from the view-model,
         so the selected mode reads at a glance rather than every mode sharing the one system accent. -->
    <Style Selector="Button.seg.selected" x:DataType="vm:ProfileButtonViewModel">
      <Setter Property="Background" Value="{Binding SelectedBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.seg:pointerover" x:DataType="vm:ProfileButtonViewModel">
      <Setter Property="Background" Value="{Binding HoverBrush}" />
    </Style>
    <Style Selector="Button.seg:pressed" x:DataType="vm:ProfileButtonViewModel">
      <Setter Property="Background" Value="{Binding PressedBrush}" />
    </Style>
    <Style Selector="Button.seg.selected:pointerover" x:DataType="vm:ProfileButtonViewModel">
      <Setter Property="Background" Value="{Binding SelectedBrush}" />
    </Style>
    <Style Selector="Button.seg.selected:pressed" x:DataType="vm:ProfileButtonViewModel">
      <Setter Property="Background" Value="{Binding SelectedBrush}" />
    </Style>
    <Style Selector="Button.seg:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{TemplateBinding Background}" />
      <Setter Property="TextBlock.Foreground" Value="{TemplateBinding Foreground}" />
    </Style>
    <Style Selector="Button.seg:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{TemplateBinding Background}" />
      <Setter Property="TextBlock.Foreground" Value="{TemplateBinding Foreground}" />
    </Style>

    <!-- Win11 quick-settings style toggles: just the switch, no "On/Off" caption, and none of the
         Fluent default ~154px MinWidth that would otherwise squeeze/clip labels in the columns. -->
    <Style Selector="ToggleSwitch">
      <Setter Property="OnContent" Value="" />
      <Setter Property="OffContent" Value="" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- Borderless icon button (drawer close): a compact square glyph, transparent at rest with a
         subtle rounded highlight on hover/press. The Fluent button paints its background on the inner
         ContentPresenter, so the states must be set there, not just on the Button. -->
    <Style Selector="Button.icon">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource AppMuted}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.icon /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppControl}" />
    </Style>
    <Style Selector="Button.icon:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppControlHover}" />
    </Style>

    <!-- Current-profile chip in the header: an accent pill with an accent dot + label. A thin accent
         border + a stronger fill keep it legible on the dark acrylic header. -->
    <Style Selector="Border.chip">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Application.Styles>
</Application>
