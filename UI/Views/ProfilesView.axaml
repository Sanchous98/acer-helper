<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             x:Class="AcerHelper.UI.Views.ProfilesView"
             x:DataType="vm:ProfilesViewModel">
  <ExperimentalAcrylicBorder Classes="card" Material="{DynamicResource CardMaterial}">
    <StackPanel Spacing="8">
      <TextBlock Classes="section" Text="PERFORMANCE"/>
      <ItemsControl ItemsSource="{Binding Profiles}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ProfileButtonViewModel">
            <Button Classes="seg" Classes.selected="{Binding IsSelected}"
                    Content="{Binding Name}" Command="{Binding ApplyCommand}"
                    IsEnabled="{Binding IsEnabled}"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Turbo shown as a switch layered over the selected base profile ("Turbo key toggles Turbo"). -->
      <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding ShowTurboSwitch}" Margin="2,2,2,0">
        <TextBlock Text="Turbo" FontWeight="SemiBold" VerticalAlignment="Center"/>
        <ToggleSwitch Grid.Column="1" IsChecked="{Binding TurboOn, Mode=TwoWay}" IsEnabled="{Binding TurboEnabled}"/>
      </Grid>
    </StackPanel>
  </ExperimentalAcrylicBorder>
</UserControl>
