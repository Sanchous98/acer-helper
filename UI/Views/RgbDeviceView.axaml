<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             x:Class="AcerHelper.UI.Views.RgbDeviceView"
             x:DataType="vm:RgbDeviceViewModel">
  <Border Classes="card">
    <StackPanel Spacing="8">
      <TextBlock Classes="section" Text="{Binding Title}"/>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox MinWidth="160" ItemsSource="{Binding EffectNames}"
                  SelectedIndex="{Binding SelectedEffectIndex, Mode=TwoWay}"/>
        <ColorPicker Color="{Binding Color, Mode=TwoWay}" IsEnabled="{Binding HasColor}"/>
      </StackPanel>

      <TextBlock Classes="muted" Text="Brightness"/>
      <Slider Minimum="0" Maximum="100" TickFrequency="10" Value="{Binding Brightness, Mode=TwoWay}"/>

      <TextBlock Classes="muted" Text="Speed" IsVisible="{Binding HasSpeed}"/>
      <Slider Minimum="0" Maximum="9" IsVisible="{Binding HasSpeed}" Value="{Binding Speed, Mode=TwoWay}"/>

      <Button Classes="accent" Content="Apply" HorizontalAlignment="Right" Padding="16,5"
              Command="{Binding ApplyCommand}"/>
    </StackPanel>
  </Border>
</UserControl>
