<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:l="clr-namespace:AcerHelper.Localization"
             x:Class="AcerHelper.UI.Views.FansView"
             x:DataType="vm:FansViewModel">
  <ExperimentalAcrylicBorder Classes="card" Material="{DynamicResource CardMaterial}">
    <StackPanel Spacing="8">
      <TextBlock Classes="section" Text="{l:Tr FANS}"/>

      <StackPanel Orientation="Horizontal" Spacing="14">
        <RadioButton GroupName="fan" Content="{l:Tr Auto}"   IsChecked="{Binding IsAuto, Mode=TwoWay}"/>
        <RadioButton GroupName="fan" Content="{l:Tr Max}"    IsChecked="{Binding IsMax, Mode=TwoWay}"    IsVisible="{Binding HasMax}"/>
        <RadioButton GroupName="fan" Content="{l:Tr Custom}" IsChecked="{Binding IsCustom, Mode=TwoWay}" IsVisible="{Binding HasCustom}"/>
      </StackPanel>

      <!-- CPU: fixed slider (disabled when its curve is on) + a Curve button that opens the modal graph. -->
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <TextBlock Classes="muted" Width="34" VerticalAlignment="Center" Text="CPU"/>
        <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10" VerticalAlignment="Center"
                IsEnabled="{Binding CpuSliderEnabled}" Value="{Binding Cpu, Mode=TwoWay}"/>
        <TextBlock Grid.Column="2" Width="42" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" Text="{Binding CpuPct}"/>
        <Button Grid.Column="3" Content="{l:Tr Curve}" Padding="10,4" Margin="8,0,0,0"
                IsVisible="{Binding HasCustom}" IsEnabled="{Binding CurveEnabled}"
                Classes.accent="{Binding CpuUseCurve}" Command="{Binding OpenCpuCurveCommand}"/>
      </Grid>

      <!-- GPU (only if a second fan exists). -->
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" IsVisible="{Binding HasGpu}">
        <TextBlock Classes="muted" Width="34" VerticalAlignment="Center" Text="GPU"/>
        <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10" VerticalAlignment="Center"
                IsEnabled="{Binding GpuSliderEnabled}" Value="{Binding Gpu, Mode=TwoWay}"/>
        <TextBlock Grid.Column="2" Width="42" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" Text="{Binding GpuPct}"/>
        <Button Grid.Column="3" Content="{l:Tr Curve}" Padding="10,4" Margin="8,0,0,0"
                IsVisible="{Binding HasCustom}" IsEnabled="{Binding CurveEnabled}"
                Classes.accent="{Binding GpuUseCurve}" Command="{Binding OpenGpuCurveCommand}"/>
      </Grid>

    </StackPanel>
  </ExperimentalAcrylicBorder>
</UserControl>
