<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             x:Class="AcerHelper.UI.Views.OptionsView"
             x:DataType="vm:OptionsViewModel">

  <!-- Bare list of option rows; the side drawer supplies the surrounding panel and title. The per-row
       item templates (ToggleRowViewModel / ChoiceRowViewModel) live in App.axaml at application scope so
       they resolve reliably — a control-level ItemsControl.DataTemplates copy left the rows unrendered. -->
  <ItemsControl ItemsSource="{Binding Rows}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate><StackPanel Spacing="14"/></ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
  </ItemsControl>
</UserControl>
