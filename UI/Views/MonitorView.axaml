<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:ui="clr-namespace:AcerHelper.UI"
             x:Class="AcerHelper.UI.Views.MonitorView"
             x:DataType="vm:MonitorViewModel">
  <Border Classes="card">
    <!-- CPU and GPU as two aligned columns; each: label, temperature, then fan speed. -->
    <Grid ColumnDefinitions="*,*" IsVisible="{Binding ShowTemps}">

      <StackPanel Spacing="2" IsVisible="{Binding ShowCpu}">
        <TextBlock Classes="muted" Text="CPU"/>
        <TextBlock Classes="metric" Text="{Binding CpuTemp}"/>
        <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,6,0,0" IsVisible="{Binding ShowCpuFan}">
          <ui:FanSpinner VerticalAlignment="Center" Blades="{DynamicResource AppMuted}"/>
          <TextBlock Classes="muted" VerticalAlignment="Center" Text="{Binding CpuFan}"/>
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1" Spacing="2" IsVisible="{Binding ShowGpu}">
        <TextBlock Classes="muted" Text="GPU"/>
        <TextBlock Classes="metric" Text="{Binding GpuTemp}"/>
        <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,6,0,0" IsVisible="{Binding ShowGpuFan}">
          <ui:FanSpinner VerticalAlignment="Center" Blades="{DynamicResource AppMuted}"/>
          <TextBlock Classes="muted" VerticalAlignment="Center" Text="{Binding GpuFan}"/>
        </StackPanel>
      </StackPanel>

    </Grid>
  </Border>
</UserControl>
