<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:views="clr-namespace:AcerHelper.UI.Views"
             x:Class="AcerHelper.UI.Views.LightingView"
             x:DataType="vm:LightingViewModel">

  <!-- One tab per RGB zone the device advertises — built entirely from the bound Panels collection, so it
       adapts to any number of zones (keyboard, lightbar, or whatever a controller exposes). Each tab's
       content is the adaptive LightView; with a single zone there is just one tab. The tab strip wraps so an
       arbitrary zone count never clips. -->
  <TabControl ItemsSource="{Binding Panels}" Padding="0">
    <TabControl.ItemsPanel>
      <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
    </TabControl.ItemsPanel>
    <TabControl.ItemTemplate>
      <DataTemplate x:DataType="vm:LightViewModel">
        <TextBlock Text="{Binding Title}"/>
      </DataTemplate>
    </TabControl.ItemTemplate>
    <TabControl.ContentTemplate>
      <DataTemplate x:DataType="vm:LightViewModel">
        <views:LightView/>
      </DataTemplate>
    </TabControl.ContentTemplate>
  </TabControl>
</UserControl>
