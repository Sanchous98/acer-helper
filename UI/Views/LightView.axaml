<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:l="clr-namespace:AcerHelper.Localization"
             x:Class="AcerHelper.UI.Views.LightView"
             x:DataType="vm:LightViewModel">

  <StackPanel Spacing="12" Margin="0,8,0,0">

    <!-- Effect picker (always present) -->
    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding EffectNames}"
              SelectedIndex="{Binding SelectedEffectIndex, Mode=TwoWay}"/>

    <!-- Per-zone colours — static effect on a multi-zone keyboard. Each swatch is editable + live. -->
    <ItemsControl ItemsSource="{Binding Zones}" IsVisible="{Binding ShowZones}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ZoneColorViewModel">
          <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="2,0">
            <ColorPicker HorizontalAlignment="Center" Color="{Binding Color, Mode=TwoWay}"/>
            <TextBlock Classes="muted" HorizontalAlignment="Center" Text="{Binding Label}"/>
          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Single colour — breathing, or static on a single-zone light (e.g. the lightbar). -->
    <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding ShowSingleColor}">
      <TextBlock Classes="muted" VerticalAlignment="Center" Width="64" Text="{l:Tr Colour}"/>
      <ColorPicker Color="{Binding Color, Mode=TwoWay}"/>
    </StackPanel>

    <!-- Brightness (always) -->
    <Grid ColumnDefinitions="64,*,44">
      <TextBlock Classes="muted" VerticalAlignment="Center" Text="{l:Tr Brightness}"/>
      <Slider Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10" VerticalAlignment="Center"
              Value="{Binding Brightness, Mode=TwoWay}"/>
      <TextBlock Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right"
                 Text="{Binding Brightness, StringFormat='{}{0:0}%'}"/>
    </Grid>

    <!-- Speed — only for effects that have a speed -->
    <Grid ColumnDefinitions="64,*,44" IsVisible="{Binding HasSpeed}">
      <TextBlock Classes="muted" VerticalAlignment="Center" Text="{l:Tr Speed}"/>
      <Slider Grid.Column="1" Minimum="0" Maximum="9" VerticalAlignment="Center"
              Value="{Binding Speed, Mode=TwoWay}"/>
      <TextBlock Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right"
                 Text="{Binding Speed, StringFormat='{}{0:0}'}"/>
    </Grid>

    <!-- Direction — only for directional effects (e.g. Wave) -->
    <Grid ColumnDefinitions="64,*" IsVisible="{Binding HasDirection}">
      <TextBlock Classes="muted" VerticalAlignment="Center" Text="{l:Tr Direction}"/>
      <ToggleSwitch Grid.Column="1" HorizontalAlignment="Left"
                    IsChecked="{Binding ReverseDirection, Mode=TwoWay}"
                    OffContent="{l:Tr Normal}" OnContent="{l:Tr Reversed}"/>
    </Grid>

  </StackPanel>
</UserControl>
