<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:l="clr-namespace:AcerHelper.Localization"
             x:Class="AcerHelper.UI.Views.TuningView"
             x:DataType="vm:TuningViewModel">

  <!-- The Tuning drawer body: each present child (GPU clock offsets / CPU power mode) in its own acrylic card
       with a section header — the SAME frosted, borderless card as the main-page sections (Monitor/Fans/…).
       The child views (GpuView/CpuView) are bare and rendered via their DataTemplates. Cards carry their own
       bottom margin (see the .card style), so no outer spacing. -->
  <StackPanel>

    <ExperimentalAcrylicBorder Classes="card" Material="{DynamicResource CardMaterial}" IsVisible="{Binding HasGpu}">
      <StackPanel Spacing="8">
        <TextBlock Classes="section" Text="{l:Tr GPU}"/>
        <ContentControl Content="{Binding Gpu}"/>
      </StackPanel>
    </ExperimentalAcrylicBorder>

    <ExperimentalAcrylicBorder Classes="card" Material="{DynamicResource CardMaterial}" IsVisible="{Binding HasCpu}">
      <StackPanel Spacing="8">
        <TextBlock Classes="section" Text="{l:Tr CPU}"/>
        <ContentControl Content="{Binding Cpu}"/>
      </StackPanel>
    </ExperimentalAcrylicBorder>

  </StackPanel>
</UserControl>
