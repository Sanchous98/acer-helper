<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
             xmlns:l="clr-namespace:AcerHelper.Localization"
             x:Class="AcerHelper.UI.Views.GpuView"
             x:DataType="vm:GpuViewModel">

  <!-- Bare drawer content; the side drawer supplies the surrounding panel and the "GPU" title. -->
  <StackPanel Spacing="14">

    <!-- Which GPU is being tuned (driver-reported name) + a Reset-to-stock button. Name trimmed so a long
         name can't widen the fixed flyout. -->
    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
      <TextBlock Classes="muted" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                 ToolTip.Tip="{Binding GpuName}" Text="{Binding GpuName}"/>
      <Button Grid.Column="1" Content="{l:Tr Reset}" Padding="10,4" Command="{Binding ResetCommand}"/>
    </Grid>

    <!-- Core clock offset (MHz). -->
    <Grid ColumnDefinitions="Auto,*,Auto">
      <TextBlock Classes="muted" Width="64" VerticalAlignment="Center" Text="{l:Tr Core}"/>
      <Slider Grid.Column="1" Minimum="{Binding CoreMin}" Maximum="{Binding CoreMax}" TickFrequency="25"
              VerticalAlignment="Center" Value="{Binding Core, Mode=TwoWay}"/>
      <TextBlock Grid.Column="2" Width="72" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center"
                 Text="{Binding CoreLabel}"/>
    </Grid>

    <!-- Memory clock offset (MHz). Raw memory-clock offset (G-Helper convention), not the doubled
         "effective" figure Afterburner shows. -->
    <Grid ColumnDefinitions="Auto,*,Auto">
      <TextBlock Classes="muted" Width="64" VerticalAlignment="Center" Text="{l:Tr Memory}"/>
      <Slider Grid.Column="1" Minimum="{Binding MemMin}" Maximum="{Binding MemMax}" TickFrequency="50"
              VerticalAlignment="Center" Value="{Binding Mem, Mode=TwoWay}"/>
      <TextBlock Grid.Column="2" Width="72" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center"
                 Text="{Binding MemLabel}"/>
    </Grid>

  </StackPanel>
</UserControl>
