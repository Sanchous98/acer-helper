<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AcerHelper.UI.ViewModels"
        xmlns:views="clr-namespace:AcerHelper.UI.Views"
        x:Class="AcerHelper.UI.LightingWindow"
        x:DataType="vm:LightingViewModel"
        Title="Acer Helper — Lighting" Width="480" CanResize="False" ShowInTaskbar="False"
        SizeToContent="Height" WindowStartupLocation="CenterScreen"
        Topmost="True" Background="Transparent">

  <!-- One tab per light the device actually exposes (keyboard / lightbar). Each tab's content is the
       adaptive LightView. With a single light there is just one tab. -->
  <Border Classes="root">
    <DockPanel Margin="14">
      <TextBlock DockPanel.Dock="Top" Classes="h1" Margin="2,0,0,10" Text="Lighting"/>
      <TabControl ItemsSource="{Binding Panels}" Padding="0">
        <TabControl.ItemTemplate>
          <DataTemplate x:DataType="vm:LightViewModel">
            <TextBlock Text="{Binding Title}"/>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate x:DataType="vm:LightViewModel">
            <views:LightView/>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>
    </DockPanel>
  </Border>
</Window>
