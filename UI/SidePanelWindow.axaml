<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AcerHelper.UI.SidePanelWindow"
        Title="Acer Helper" Width="360" CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="Manual" WindowDecorations="None" Background="Transparent">

  <!-- A side panel (Options / Lighting) pinned to the left of the main flyout. The window stays put
       (no move -> no DWM-blur flicker, and it never overlaps the main window so nothing bleeds through
       its acrylic). The open/close/switch "slide behind the main window" effect is done by translating
       the inner content toward the main-adjacent (right) edge, clipped by the rounded body. -->
  <Border Classes="root" ClipToBounds="True">
    <DockPanel x:Name="Body" Margin="14">
      <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
        <Button x:Name="BackButton" Classes="icon" Content="&#x2190;"/>
        <TextBlock x:Name="TitleText" Grid.Column="1" Classes="h1" VerticalAlignment="Center" Margin="6,0,0,0"/>
      </Grid>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ContentControl x:Name="ContentHost"/>
      </ScrollViewer>
    </DockPanel>
  </Border>
</Window>
