<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AcerHelper.UI.SidePanelWindow"
        Title="Acer Helper" Width="360" CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="Manual" WindowDecorations="None" Background="Transparent">

  <!-- Options/Lighting side panel: a separate acrylic window shown to the left of the main flyout.
       It is shown/hidden (no animation) and never moves once placed, so there's no resize ghosting
       or flicker, and it never overlaps the main window so nothing bleeds through the acrylic. -->
  <Border Classes="root">
    <DockPanel Margin="14">
      <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
        <Button x:Name="BackButton" Classes="icon" Content="&#x2190;"/>
        <TextBlock x:Name="TitleText" Grid.Column="1" Classes="h1" VerticalAlignment="Center" Margin="6,0,0,0"/>
      </Grid>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ContentControl x:Name="ContentHost"/>
      </ScrollViewer>
    </DockPanel>
  </Border>
</Window>
