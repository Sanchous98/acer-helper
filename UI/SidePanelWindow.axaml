<ui:FlyoutWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:AcerHelper.UI"
        x:Class="AcerHelper.UI.SidePanelWindow"
        Title="Acer Helper" Width="400" CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="Manual" WindowDecorations="None" Background="Black"
        Topmost="True" TransparencyLevelHint="Transparent">

  <!-- Options/Lighting drawer: a separate window to the left of the main flyout, sized to its own
       content width (400 = 360 card + 2*20 shadow margin). Height is set by AppController to match the
       main flyout. Same as the main window, we animate the CONTENT (this Border), not the Window: it's
       shown at full size with the content transparent so KWin's map effect plays over nothing, then
       SlideFader reveals. AppController positions it flush-left of the main card. -->
  <Panel x:Name="Backdrop" Background="Transparent">
  <Border x:Name="Root" Width="360" Margin="20"
          Background="{DynamicResource AppAcrylicTint}"
          CornerRadius="{DynamicResource OverlayCornerRadius}"
          ClipToBounds="True"
          BoxShadow="0 4 16 0 #55000000"
          Opacity="0" RenderTransform="translateX(26px)">
    <Border.Transitions>
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut"/>
      </Transitions>
    </Border.Transitions>
    <DockPanel Margin="14">
      <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
        <TextBlock x:Name="TitleText" Classes="h1" VerticalAlignment="Center"/>
        <!-- Close points toward the main window (to the right); vector so it's centred. -->
        <Button x:Name="BackButton" Grid.Column="1" Classes="icon">
          <Path Width="11" Height="10" Stretch="None"
                Stroke="{DynamicResource AppMuted}" StrokeThickness="1.6"
                StrokeLineCap="Round" StrokeJoin="Round"
                Data="M1,5 H10 M6.5,1.5 L10,5 L6.5,8.5"/>
        </Button>
      </Grid>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ContentControl x:Name="ContentHost"/>
      </ScrollViewer>
    </DockPanel>
  </Border>
  </Panel>
</ui:FlyoutWindow>
