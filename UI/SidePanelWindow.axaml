<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AcerHelper.UI.SidePanelWindow"
        Title="Acer Helper" Width="400" CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="Manual" WindowDecorations="None" Background="Transparent"
        Topmost="True">

  <!-- Options/Lighting side panel. Everything is app-painted (no DWM): the blur is an Avalonia
       ExperimentalAcrylicBorder and the shadow is a BoxShadow, so the whole panel — blur, shadow and
       content — fades out together with the window. The 20px margin is room for the shadow. The
       window never moves; slide/fade animate Root. -->
  <Border x:Name="Root" Margin="20"
          CornerRadius="{DynamicResource OverlayCornerRadius}"
          BoxShadow="0 4 16 0 #55000000">
    <ExperimentalAcrylicBorder CornerRadius="{DynamicResource OverlayCornerRadius}"
                               ClipToBounds="True"
                               Material="{DynamicResource SidePanelAcrylic}">
      <DockPanel Margin="14">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
          <TextBlock x:Name="TitleText" Classes="h1" VerticalAlignment="Center"/>
          <!-- Close points toward the main window (to the right); vector so it's centred. -->
          <Button x:Name="BackButton" Grid.Column="1" Classes="icon">
            <Path Width="11" Height="10" Stretch="None"
                  Stroke="{DynamicResource AppMuted}" StrokeThickness="1.6"
                  StrokeLineCap="Round" StrokeJoin="Round"
                  Data="M1,5 H10 M6.5,1.5 L10,5 L6.5,8.5"/>
          </Button>
        </Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <ContentControl x:Name="ContentHost"/>
        </ScrollViewer>
      </DockPanel>
    </ExperimentalAcrylicBorder>
  </Border>
</Window>
